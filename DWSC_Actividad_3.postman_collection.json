  "item": [
    {
      "name": "1. GET: Listar todos los usuarios (Ordenados por Username - C# LINQ)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/users",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "users"
          ]
        },
        "description": "Obtiene la lista de usuarios. El código C# se encarga de ordenarlos por Username usando `.OrderBy()` en memoria."
      },
      "response": []
    },
    {
