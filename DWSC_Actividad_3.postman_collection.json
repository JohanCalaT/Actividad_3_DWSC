          "raw": "{{base_url}}/api/users",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "users"
          ]
        },
        "description": "Valida que el servidor pueda responder en formato XML si el cliente lo solicita mediante la cabecera `Accept: application/xml`."
      },
      "response": []
    },
